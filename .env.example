# DashScope Configuration (Alibaba Cloud - qwen models)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_TEXT_MODEL=qwen3-max
DASHSCOPE_IMAGE_MODEL=wan2.6-t2i

# 火山引擎方舟 Configuration (Seedream for image generation)
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seedream-4-5-251128
ARK_IMAGE_SIZE=2560x1440

# IndexTTS Configuration (UCloud Modelverse API)
INDEXTTS_API_KEY=your-indextts-api-key
INDEXTTS_BASE_URL=https://api.modelverse.cn
INDEXTTS_MODEL=IndexTeam/IndexTTS-2
INDEXTTS_VOICE=jack_cheng

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_DATABASE=video_generator

# Tencent Cloud COS Configuration
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your-bucket-name
COS_REGION=ap-guangzhou

# Tencent Cloud SCF (Serverless Cloud Function) for ZIP export
# Deploy the function from scripts/scf_zip_exporter/
SCF_ZIP_URL=https://service-xxx.gz.apigw.tencentcs.com/release/cos-zip-exporter

# Admin User
ADMIN_USERNAME=admin
ADMIN_PASSWORD=video123
ADMIN_EMAIL=admin@example.com
